{
  "$schema": "./node_modules/@tauri-apps/cli/config.schema.json",
  "build": {
    "frontendDist": "../build/tauri/public"
  },
  "app": {
    "windows": [
      {
        "title": "AITranscriber",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "visible": false,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "resources": {
      "../build/vad": "vad",
      "../artisan": "artisan",
      "../composer.json": "composer.json",
      "../app": "app",
      "../bootstrap": "bootstrap",
      "../config": "config",
      "../build/tauri/database/database.sqlite": "database/database.sqlite",
      "../build/tauri/version.json": "version.json",
      "../database/factories": "database/factories",
      "../database/migrations": "database/migrations",
      "../database/seeders": "database/seeders",
      "../build/tauri/public": "public",
      "../resources": "resources",
      "../routes": "routes",
      "../vendor": "vendor",
      "../.env": ".env",
      "../php": "php",
      "../ffmpeg": "ffmpeg",
      "../sherpa": "sherpa",
      "target/release/sherpa-onnx-c-api.dll": "sherpa-onnx-c-api.dll",
      "target/release/onnxruntime.dll": "onnxruntime.dll",
      "target/release/onnxruntime_providers_shared.dll": "onnxruntime_providers_shared.dll"
    }
  }
}
