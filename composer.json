{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.8",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            ".\\php\\php.exe .\\composer.phar install",
            ".\\php\\php.exe -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            ".\\php\\php.exe artisan key:generate",
            ".\\php\\php.exe artisan migrate --force",
            ".\\node\\npm.cmd install --ignore-scripts",
            ".\\node\\npm.cmd run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve --host=127.0.0.1 --port=8010\" \"php artisan queue:work --sleep=1 --tries=3 --timeout=0\" \"npm run dev\" --names=server,queue,vite --kill-others"
        ],
        "dev:local": [
            "Composer\\Config::disableProcessTimeout",
            ".\\php\\php.exe scripts\\clear-dev-port.php 8010",
            ".\\php\\php.exe scripts\\clear-dev-port.php 5173",
            ".\\node\\npx.cmd concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \".\\php\\php.exe artisan serve --host=127.0.0.1 --port=8010\" \".\\php\\php.exe artisan queue:work --sleep=1 --tries=3 --timeout=0\" \".\\node\\npm.cmd run dev\" --names=server,queue,vite"
        ],
        "test": [
            ".\\php\\php.exe artisan config:clear --ansi",
            ".\\php\\php.exe artisan test"
        ],
        "analyse": [
            ".\\php\\php.exe vendor\\bin\\phpstan analyse --memory-limit=1G"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            ".\\php\\php.exe artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            ".\\php\\php.exe artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            ".\\php\\php.exe -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            ".\\php\\php.exe artisan key:generate --ansi",
            ".\\php\\php.exe -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            ".\\php\\php.exe artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
