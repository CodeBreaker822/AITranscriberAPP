e', 'string', 'max:32'],\\n\n            'transcription_engine' => ['nullable', 'string', 'in:online,offline'],\\n\n            'whisper_model' => ['nullable', 'string', 'in:tiny,small,medium,large,turbo'],\\n\n            'speaker_session_id' => ['nullable', 'string', 'max:120', 'regex:/^[A-Za-z0-9._:-]+$/'],\\n\n            'progress_id' => ['nullable', 'string', 'max:120', 'regex:/^[A-Za-z0-9._:-]+$/'],\\n\n            'finalize_session' => ['nullable', 'boolean'],\\n\n        ]));\\n\n    }\\n\n\\n\n    public function prepareUploadedSection(\\n\n        Request $request,\\n\n        UploadedAudioSectionPreparationService $preparer,\\n\n    ): JsonResponse {\\n\n        @set_time_limit(0);\\n\n\\n\n        $validated = $request->validate([\\n\n            'upload_session_id' => ['required', 'string', 'max:80'],\\n\n            'user_id' => ['nullable', 'integer', 'min:1'],\\n\n            'category_name' => ['required', 'string', 'max:120'],\\n\n            'clip_index' => ['required', 'integer', 'min:1'],\\n\n            'clip_start_ms' => ['required', 'integer', 'min:0'],\\n\n            'clip_end_ms' => ['required', 'integer', 'min:0'],\\n\n            'range_label' => ['required', 'string', 'max:32'],\\n\n            'duration_ms' => ['required', 'integer', 'min:1'],\\n\n        ]);\\n\n\\n\n        try {\\n\n            return response()->json([\\n\n                'message' => 'prepared',\\n\n                'data' => $preparer->prepare($validated),\\n\n            ]);\\n\n        } catch (RuntimeException $exception) {\\n\n            Log::error('Uploaded audio section could not be prepared.', [\\n\n                'message' => $exception->getMessage(),\\n\n                'clip_index' => (int) $validated['clip_index'],\\n\n                'range_label' => $validated['range_label'],\\n\n            ]);\\n\n\\n\n            return response()->json([\\n\n                'message' => $exception->getMessage(),\\n\n            ], 422);\\n\n        }\\n\n    }\\n\n\\n\n    public function uploadSessionStatus(Request $request, AudioFileChunkerService $chunker): JsonResponse\\n\n    {\\n\n        $validated = $request->validate([\\n\n            'session_id' => ['required', 'string', 'max:80', 'regex:/^[A-Za-z0-9-]+$/'],\\n\n        ]);\\n\n\\n\n        return response()->json([\\n\n            'available' => $chunker->sessionAvailable($validated['session_id']),\\n\n        ]);\\n\n    }\\n\n\\n\n    public function prepareUploadedSectionsBatch(\\n\n        Request $request,\\n\n        UploadedAudioBatchPreparationService $preparer,\\n\n    ): JsonResponse {\\n\n        @set_time_limit(0);\\n\n\\n\n        $validated = $request->validate([\\n\n            'upload_session_id' => ['required', 'string', 'max:80'],\\n\n            'user_id' => ['nullable', 'integer', 'min:1'],\\n\n            'category_name' => ['required', 'string', 'max:120'],\\n\n            'concurrency' => ['nullable', 'integer', 'min:1', 'max:64'],\\n\n            'sections' => ['required', 'array', 'min:1'],\\n\n            'sections.*.clip_index' => ['required', 'integer', 'min:1'],\\n\n            'sections.*.clip_start_ms' => ['required', 'integer', 'min:0'],\\n\n            'sections.*.clip_end_ms' => ['required', 'integer', 'min:0'],\\n\n            'sections.*.range_label' => ['required', 'string', 'max:32'],\\n\n            'sections.*.duration_ms' => ['required', 'integer', 'min:1'],\\n\n        ]);\\n\n\\n\n        try {\\n\n            return response()->json($preparer->prepare($validated));\\n\n        } catch (RuntimeException $exception) {\\n\n            return response()->json([\\n\n                'message' => $exception->getMessage(),\\n\n            ], 422);\\n\n        }\\n\n    }\\n\n\\n\n    public function storeBatch(Request $request, AudioChunkIngestionService $ingestion): JsonResponse\\n\n    {\\n\n        return $ingestion->storeUploadedBatch($request->validate([\\n\n            'upload_session_id' => ['required', 'string', 'max:80'],\\n\n            'user_id' => ['nullable', 'integer', 'min:1'],\\n\n            'category_name' => ['required', 'string', 'max:120'],\\n\n            'language_code' => ['nullable', 'string', 'max:32'],\\n\n            'transcription_engine' => ['nullable', 'string', 'in:online'],\\n\n            'whisper_model' => ['nullable', 'string', 'in:tiny,small,medium,large,turbo'],\\n\n            'speaker_session_id' => ['nullable', 'string', 'max:120', 'regex:/^[A-Za-z0-9._:-]+$/'],\\n\n            'progress_id' => ['nullable', 'string', 'max:120', 'regex:/^[A-Za-z0-9._:-]+$/'],\\n\n            'finalize_session' => ['nullable', 'boolean'],\\n\n            'sections' => ['required', 'array', 'min:1', 'max:20'],\\n\n            'sections.*.clip_index' => ['required', 'integer', 'min:1'],\\n\n            'sections.*.clip_start_ms' => ['required', 'integer', 'min:0'],\\n\n            'sections.*.clip_end_ms' => ['required', 'integer', 'min:0'],\\n\n            'sections.*.range_label' => ['required', 'string', 'max:32'],\\n\n            'sections.*.duration_ms' => ['required', 'integer', 'min:1'],\\n\n            'sections.*.prepared_name' => ['nullable', 'string', 'regex:/^chunk_\\d+(?:-speech)?\\.wav$/i'],\\n\n            'sections.*.source_name' => ['nullable', 'string', 'regex:/^chunk_\\d+\\.wav$/i'],\\n\n            'sections.*.prepared_skipped' => ['nullable', 'boolean'],\\n\n        ]));\\n\n    }\\n\n\\n\n    public function audio(int $audioChunk, AudioChunkPersistenceService $audioChunks): Response|BinaryFileResponse\\n\n    {\\n\n        return $audioChunks->audioResponse($audioChunk);\\n\n    }\\n\n\\n\n    public function destroy(int $audioChunk, AudioChunkPersistenceService $audioChunks): JsonResponse\\n\n    {\\n\n        $result = $audioChunks->destroy($audioChunk);\\n\n\\n\n        return response()->json($result['data'], $result['status']);\\n\n    }\\n\n\\n\n    public function releaseSpeakerSession(\\n\n        Request $request,\\n\n        SpeakerDiarizationService $speakerDiarization,\\n\n    ): JsonResponse {\\n\n        $validated = $request->validate([\\n\n            'speaker_session_id' => ['required', 'string', 'max:120', 'regex:/^[A-Za-z0-9._:-]+$/'],\\n\n        ]);\\n\n\\n\n        $speakerDiarization->releaseSession((string) $validated['speaker_session_id']);\\n\n\\n\n        return response()->json(['message' => 'released']);\\n\n    }\\n\n\\n\n    private function uploadedSectionRules(): array\\n\n    {\\n\n        return [\\n\n            'upload_session_id' => ['required', 'string', 'max:80'],\\n\n            'user_id' => ['nullable', 'integer', 'min:1'],\\n\n            'category_name' => ['required', 'string', 'max:120'],\\n\n            'clip_index' => ['required', 'integer', 'min:1'],\\n\n            'clip_start_ms' => ['required', 'integer', 'min:0'],\\n\n            'clip_end_ms' => ['required', 'integer', 'min:0'],\\n\n            'range_label' => ['required', 'string', 'max:32'],\\n\n            'duration_ms' => ['required', 'integer', 'min:1'],\\n\n            'language_code' => ['nullable', 'string', 'max:32'],\\n\n            'transcription_engine' => ['nullable', 'string', 'in:online,offline'],\\n\n            'whisper_model' => ['nullable', 'string', 'in:tiny,small,medium,large,turbo'],\\n\n            'speaker_session_id' => ['nullable', 'string', 'max:120', 'regex:/^[A-Za-z0-9._:-]+$/'],\\n\n            'progress_id' => ['nullable', 'string', 'max:120', 'regex:/^[A-Za-z0-9._:-]+$/'],\\n\n            'finalize_session' => ['nullable', 'boolean'],\\n\n            'prepared_name' => ['nullable', 'string', 'regex:/^chunk_\\d+(?:-speech)?\\.wav$/i'],\\n\n            'source_name' => ['nullable', 'string', 'regex:/^chunk_\\d+\\.wav$/i'],\\n\n            'prepared_skipped' => ['nullable', 'boolean'],\\n\n        ];\\n\n    }\\n\n}\\n\n' [ASCII](length: 8837) contains \"DiarizeUploadedAudioBatch::dispatch(\" [ASCII](length: 36)."}],"risky":1}
